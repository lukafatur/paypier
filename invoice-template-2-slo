<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>A4 Document</title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            background-color: #EEE8DC !important;
            font-family: 'Poppins', Arial, sans-serif;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .document {
            width: 210mm;
            min-height: 297mm;
            margin: 0 auto; 
            position: relative; 
            background-color: #EEE8DC;
            box-sizing: border-box;
        }

        /* Sidebar styling */
        .sidebar {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 150px;
            border-right: 1px solid #10207E;
            box-sizing: border-box;
        }

        .sidebar-content {
            position: sticky;
            top: 0;
            height: 100vh; 
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 150px 0;
            box-sizing: border-box;
        }

        .main-content {
            margin-left: 150px; 
            padding-bottom: 50px;
            min-height: 100%;
            box-sizing: border-box;
        }

        @media print {
            @page { 
                size: A4; 
                margin: 0; /* Keeps the background full-bleed */
            }
            body { 
                background-color: #EEE8DC !important; 
            }
            .document {
                width: 100%;
                margin: 0;
                min-height: auto;
                display: block; 
            }
            
            /* Sidebar perfectly repeats on EVERY printed page */
            .sidebar {
                position: fixed; 
                height: 100%; 
            }
            .sidebar-content {
                position: absolute; 
                height: 100%; 
            }

            .main-content {
                margin-left: 150px;
                display: block !important; /* Force block to allow normal page flow */
                padding-top: 40px; /* Space from top of page so text doesn't hit edge */
            }

            /* 1. Kill Flexbox in Print Flow (Root cause of overlapping) */
            .top-row, .middle-row, .bottom-row, .wrapper-2 {
                display: block !important;
            }

            /* 2. Convert Flex Rows to Table Layouts for safe side-by-side pagination */
            .wrapper, .wrapper-3, .total-row {
                display: table !important;
                width: 80% !important;
                margin: 0 auto !important;
            }
            .wrapper-3 { margin: 0 10% !important; }

            .wrapper > div, .wrapper-3 > div, .total-row > h1 {
                display: table-cell !important;
                vertical-align: top !important;
            }
            
            /* Mimic original alignments lost from removing flexbox */
            .top-row .wrapper > div:last-child { text-align: right !important; }
            .total-row > h1:last-child { text-align: right !important; }
            .wrapper-3 > div:first-child { padding-right: 100px !important; }

            /* 3. Bulletproof Table Pagination and Repeating Headers */
            .top-row {
                padding-bottom: 0px !important; /* Remove bottom padding to balance header space on page 1 */
            }
            .invoice-table { 
                margin-top: 0px !important; /* Remove top margin to balance header space on page 1 */
                page-break-inside: auto !important; 
                border-collapse: separate !important; 
                border-spacing: 0 !important;
            }
            .invoice-table thead { 
                display: table-header-group !important; /* Forces column titles to repeat on new pages */
            }
            .invoice-table th {
                padding-top: 100px !important; /* Acts as the missing top margin for the repeated header on Page 2 */
                background-color: #EEE8DC !important; /* Solid background prevents Chrome's text overlap bug */
                border-bottom: 1px solid #10207E !important;
            }
            .invoice-table tr { 
                page-break-inside: avoid !important; 
                break-inside: avoid !important;
                page-break-after: auto !important; 
            }

            /* 4. Prevent large section splitting */
            .top-row, .total-row { 
                page-break-inside: avoid !important; 
                break-inside: avoid !important;
            }
            .bottom-row {
                page-break-inside: avoid !important; 
                break-inside: avoid !important;
                padding-top: 100px !important; /* Top margin in case PLAČILA section gets pushed to Page 2 */
            }
        }

        .rotated-text {
            transform: rotate(-90deg);
            white-space: nowrap;
            text-align: center;
            font-size: 60px;
            width: 150px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #10207E;
        }

        .content {
            color: #10207E;
            line-height: 16px;
        }

        h1 {
            font-size: 20px;
            color: #10207E;
            margin-top: 0;
            margin-bottom: 10px;
        }

        p {
            font-size: 14px;
            color: #10207E;
            line-height: 16px;
            margin: 0;
        }

        .important {
            font-size: 16px;
            margin-bottom: 5px;
        }

        .due-date {
            background-color: #10207E;
            color: white;
            padding: 10px 10px;
            margin-top: 10px;
            border-radius: 5px;
            display: inline-block;
        }

        .invoice-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            color: #10207E;
        }

        .invoice-table th {
            text-align: left;
            padding: 15px 10px;
            border-bottom: 1px solid #10207E;
            font-size: 14px;
            text-transform: uppercase;
        }

        .invoice-table td {
            padding: 15px 10px;
            font-size: 14px;
            vertical-align: top;
        }

        .invoice-table tbody tr:last-child td {
            border-bottom: 1px solid #10207E;
        }

        .invoice-table .number-column {
            text-align: right;
        }

        .wrapper {
            width: 80%;
            margin: 0 auto;
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-start;
        }

        .wrapper-2 {
            width: 80%;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
        }

        .wrapper-3 {
            margin: 0 10%;
            display: flex;
            flex-direction: row;
            gap: 100px;
            align-items: flex-start;
        }

        .top-row {
            border-bottom: 1px solid #10207E;
            padding-top: 100px;
            padding-bottom: 40px;
        }

        .total-row {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            padding: 20px 0;
        }

        .bottom-row {
            padding-top: 50px;
        }

        .comment {
            font-size: 10px;
        }
    </style>
</head>
<body>
    <div class="document">
        
        <!-- Left Sidebar that repeats on Print -->
        <div class="sidebar">
            <div class="sidebar-content">
                <div class="rotated-text">#{{invoice.number}}</div>
                <div class="rotated-text">{{invoice.type}}</div>
            </div>
        </div>

        <!-- Main Content Area that safely breaks across pages -->
        <div class="main-content">
            <div class="top-row">
                <div class="wrapper">
                    <div class="content">
                         <h1>PREJEMNIK</h1>
                         <p class="important">{{client.name}}</p>
                         <p class="important">{{client.address_line1}}</p>
                         <p class="important">{{client.address_line2}}</p>
                         <p class="important">{{client.vat_number}}</p>
                    </div>
                
                    <div class="content" style="text-align: right;">
                        <p class="important">Datum računa: {{invoice.date}}</p>
                        <p class="important due-date">Veljavno do: {{invoice.due_date}}</p>
                    </div>
                </div>
            </div>
            
            <div class="middle-row">
                <div class="wrapper-2">
                    <table class="invoice-table">
                        <thead>
                            <tr>
                                <th style="width: 50%">Opis</th>
                                <th class="number-column">Količina</th>
                                <th class="number-column">Cena</th>
                                <th class="number-column">Znesek</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#invoice.items}}
                            <tr>
                                <td>{{description}}</td>
                                <td class="number-column">{{qty}}</td>
                                <td class="number-column">{{price}}</td>
                                <td class="number-column">{{amount}}</td>
                            </tr>
                            {{/invoice.items}}
                        </tbody>
                        
                        <!-- Invisible footer that repeats on every page to create a safe bottom margin -->
                        <tfoot class="print-spacer">
                            <tr>
                                <td colspan="4"></td>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="total-row">
                        <h1>Skupaj</h1>
                        <h1>{{invoice.total}}</h1>
                    </div>
                </div>
            </div>

            <div class="bottom-row">
                <div class="wrapper-3" style="margin-bottom: 50px;">
                    <div class="content">
                         <h1>PLAČILA</h1>
                         <p>{{company.name}}</p>
                         <p>{{company.address_line1}}</p>
                         <p>{{company.address_line2}}</p>
                    </div>
                    <div class="content">
                        <br>
                        <p>{{company.bank}}</p>
                    </div>
                </div>
                
                <div class="wrapper">
                    <div class="content">
                         <h1>VPRAŠANJA?</h1>
                         <p>Email me at</p>
                         <p><strong>{{company.email}}</strong></p>
                    </div>
                </div>
                
                <div style="margin-top: 50px; margin-bottom: 20px;" class="wrapper">
                    <div class="content comment">
                        <p style="font-size: 10px;">{{invoice.comment}}</p>
                        <p style="font-size: 10px; margin-top: 5px;">{{company.comment}}</p>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</body>
</html>
